# =========================================================================
# Variables de entorno para GeoPlataforma
# Copia este archivo a `.env` (NO subir .env a git) y rellena los valores.
# =========================================================================

# Puerto en el que corre el servidor (Render/Railway/etc. lo inyectan auto)
PORT=3000

# =========================================================================
# SMTP — Envío de correos del formulario de contacto
# =========================================================================
# Opción recomendada: Resend (https://resend.com) — 3.000 correos/mes gratis.
# 1) Crea cuenta con info@geotrends.co
# 2) Verifica tu dominio geotrends.co (DNS: SPF + DKIM)
# 3) Crea una API Key y úsala como SMTP_PASS

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx

# --- Alternativa: Gmail con App Password ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx       # App Password (no la contraseña normal)

# --- Alternativa: Brevo (ex Sendinblue) ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_login_smtp@smtp-brevo.com
# SMTP_PASS=tu_smtp_key

# =========================================================================
# Destino y remitente de los correos del formulario
# =========================================================================
# A quién llegan los mensajes del formulario de contacto:
CONTACT_TO=info@geotrends.co

# Remitente (debe coincidir con un dominio verificado en tu proveedor SMTP):
CONTACT_FROM=GeoPlataforma <noreply@geotrends.co>
